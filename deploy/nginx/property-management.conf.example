# =============================================================================
# property-management nginx リバースプロキシ設定
# =============================================================================
# 前提:
#   - Certbot (Let's Encrypt) で SSL 証明書取得済み
#   - アプリは localhost:3000 で起動済み
#
# 使い方:
#   sudo cp deploy/nginx/property-management.conf.example \
#            /etc/nginx/sites-available/property-management
#   # <YOUR_DOMAIN> を実際のドメインに置き換える
#   sudo ln -s /etc/nginx/sites-available/property-management \
#              /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
# =============================================================================

# HTTP → HTTPS リダイレクト
server {
    listen 80;
    listen [::]:80;
    server_name <YOUR_DOMAIN>;

    # Let's Encrypt 証明書更新用
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name <YOUR_DOMAIN>;

    # Let's Encrypt 証明書 (certbot --nginx で自動設定される)
    ssl_certificate     /etc/letsencrypt/live/<YOUR_DOMAIN>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<YOUR_DOMAIN>/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # セキュリティヘッダー
    add_header X-Frame-Options        "SAMEORIGIN"  always;
    add_header X-Content-Type-Options "nosniff"     always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    # アップロード上限（MAX_FILE_SIZE=8MB に合わせて余裕を持たせる）
    client_max_body_size 12m;

    # アクセスログ
    access_log /var/log/nginx/property-management.access.log;
    error_log  /var/log/nginx/property-management.error.log;

    # Next.js アプリへリバースプロキシ
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # WebSocket サポート（将来の SSE / WS 対応に備える）
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";

        proxy_read_timeout  60s;
        proxy_send_timeout  60s;
        proxy_cache_bypass  $http_upgrade;
    }

    # Next.js 静的アセットのキャッシュ
    location /_next/static/ {
        proxy_pass         http://127.0.0.1:3000;
        proxy_cache_valid  200 1y;
        add_header         Cache-Control "public, immutable";
    }
}
