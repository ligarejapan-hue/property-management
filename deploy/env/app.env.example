# =============================================================================
# property-management 本番環境変数テンプレート
# =============================================================================
# 配置先: /etc/property-management/app.env
# 権限:   sudo chmod 600 /etc/property-management/app.env
#         sudo chown root:root /etc/property-management/app.env
#
# 注意:
#   - このファイルは git にコミットしない（.gitignore で除外済み）
#   - シークレット実値はこのチャット・ログに貼らない
#   - AUTH_TRUST_HOST は HTTPS 本番環境では不要（入れないこと）
# =============================================================================

# ----------------------------------------------------------------------------
# [必須] データベース
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://<DB_USER>:<DB_PASS>@localhost:5432/<DB_NAME>"

# ----------------------------------------------------------------------------
# [必須] NextAuth / Auth.js
# 生成: openssl rand -hex 32
# ----------------------------------------------------------------------------
NEXTAUTH_SECRET="<64文字以上のランダム文字列>"
NEXTAUTH_URL="https://<YOUR_DOMAIN>"

# ----------------------------------------------------------------------------
# [必須] ストレージサーバー
# ----------------------------------------------------------------------------
STORAGE_BACKEND=server
STORAGE_SERVER_URL="https://<STORAGE_SERVER_DOMAIN>"
STORAGE_SERVER_API_KEY="<STORAGE_API_KEY>"
STORAGE_SERVER_BUCKET=property-management

# ----------------------------------------------------------------------------
# [必須] 動作モード
# ----------------------------------------------------------------------------
NODE_ENV=production

# ----------------------------------------------------------------------------
# [推奨] 調査情報プロバイダ (KSJ 国土数値情報)
# 未設定 → KSJ プロバイダ無効（investigation は動作するが取得件数 0）
# ----------------------------------------------------------------------------
KSJ_API_URL="http://<GEOSERVER_HOST>/geoserver/ksj/ows"

# ----------------------------------------------------------------------------
# [オプション] 取込動作設定
# needs_review: 棟未存在時に needs_review ステータスで記録（デフォルト）
# auto_create:  棟を自動作成
# ----------------------------------------------------------------------------
UNIT_IMPORT_BUILDING_NOT_FOUND=needs_review

# ----------------------------------------------------------------------------
# [将来実装] 追加プロバイダ
# ----------------------------------------------------------------------------
# NTA_ROSENKA_API_URL=
# ROAD_LEDGER_API_URL=
# GOOGLE_MAPS_API_KEY=
# RESEND_API_KEY=
# EMAIL_FROM=noreply@<YOUR_DOMAIN>
