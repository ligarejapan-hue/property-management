# ============================================================
# 物件管理システム - 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください。
# 本番デプロイの詳細は docs/deploy.md を参照。
# ============================================================

# ----------------------------------------------------------------
# [必須] データベース
# ----------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/property_management"

# ----------------------------------------------------------------
# [必須] NextAuth / Auth.js
# ----------------------------------------------------------------
# 本番: openssl rand -hex 32 で生成した値を設定すること
NEXTAUTH_SECRET="change-this-to-a-secure-random-secret-in-production"

# 本番: "https://your-domain.com" に変更すること
NEXTAUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------
# [必須（本番）] ストレージ
# 開発: local (public/uploads/ に書き込み、追加設定不要)
# 本番: server (STORAGE_SERVER_* の設定も必要)
# ----------------------------------------------------------------
STORAGE_BACKEND=local

# STORAGE_BACKEND=local の保存先ルート（絶対パス）。
# 未設定なら ${cwd}/public/uploads（既存互換、開発でそのまま動く）。
# 本番でリポジトリ外に保存先を逃がしたい場合に指定する。
# LOCAL_UPLOAD_ROOT=/var/lib/property-management/uploads

# STORAGE_BACKEND=server の場合に設定:
# STORAGE_SERVER_URL=https://files.your-domain.com
# STORAGE_SERVER_API_KEY=your-api-key-here
# STORAGE_SERVER_BUCKET=property-management

# 開発用モックサーバー: npm run storage:mock
# STORAGE_SERVER_URL=http://localhost:4000
# STORAGE_SERVER_API_KEY=test-api-key

# ----------------------------------------------------------------
# [推奨] 調査情報プロバイダ (investigation)
# 国土数値情報 A29 (用途地域・建蔽率・容積率・防火地域)
# 設定なし → KSJ プロバイダ無効 (機能は動作するが取得件数 0)
# ----------------------------------------------------------------

# 開発用モックサーバー: npm run ksj:mock (port 9000)
# KSJ_API_URL=http://localhost:9000/geoserver/ksj/ows

# 本番: GeoServer WFS エンドポイント
# KSJ_API_URL=http://your-geoserver.com/geoserver/ksj/ows

# ----------------------------------------------------------------
# [オプション] 取込動作設定
# ----------------------------------------------------------------

# 区分（unit）取込時、棟が未存在の場合の動作
#   needs_review : needs_review ステータスで取込ジョブに記録 (デフォルト)
#   auto_create  : 棟を自動作成
UNIT_IMPORT_BUILDING_NOT_FOUND=needs_review

# ----------------------------------------------------------------
# [開発専用] モックモード
# DB が未接続の場合に true にするとモックデータで動作する
# ----------------------------------------------------------------
NEXT_PUBLIC_USE_MOCK=

# ----------------------------------------------------------------
# [将来実装] 追加プロバイダ・外部連携
# ----------------------------------------------------------------

# 路線価 API (将来実装)
# NTA_ROSENKA_API_URL=
# NTA_ROSENKA_API_KEY=

# 道路台帳 API (将来実装)
# ROAD_LEDGER_API_URL=

# Google Maps API (将来実装)
# GOOGLE_MAPS_API_KEY=

# メール送信 / パスワードリセット (将来実装)
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com
